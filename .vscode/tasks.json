{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Local Static Server",
      "type": "shell",
      "command": "Start-Process 'http://localhost:8000'; python -m http.server 8000",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    }
  ]
}
